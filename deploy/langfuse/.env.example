# Langfuse 自托管（复制为 deploy/langfuse/.env 后启动）
# cp deploy/langfuse/.env.example deploy/langfuse/.env

NEXTAUTH_URL=http://localhost:3000
# 必须各为 64 位十六进制（openssl rand -hex 32），占位符会导致 UI Internal Server Error
NEXTAUTH_SECRET=
ENCRYPTION_KEY=
# openssl rand -hex 16
SALT=

CLICKHOUSE_PASSWORD=clickhouse
REDIS_AUTH=myredissecret
MINIO_ROOT_PASSWORD=miniosecret
POSTGRES_PASSWORD=postgres

TELEMETRY_ENABLED=false

# 首次启动自动创建项目（将输出的 key 填入仓库根目录 .env）
LANGFUSE_INIT_ORG_NAME=pdf-agent-local
LANGFUSE_INIT_PROJECT_NAME=pdf-agent
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=pdfagent-local-admin
