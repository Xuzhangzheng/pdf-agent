# 复制为 .env 并填写密钥：cp .env.example .env
# 换机安装：bash scripts/setup.sh（见 docs/setup/environment.md）
# Docker 未就绪后补中间件：bash scripts/setup.sh services

# --- 必填 ---
DASHSCOPE_API_KEY=
ARK_API_KEY=

# --- 推荐（作业数据基线）---
PDF_PARSER_BACKEND=mineru
INDEX_HYPOTHETICAL_QUESTIONS=true
RETRIEVAL_METADATA_BOOST=0.15

# --- DashScope（Embedding / Rerank）---
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RERANKER_MODEL=qwen3-rerank

# --- 火山方舟（Chat / 反思 / 可选问句生成）---
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=doubao-1-5-lite-32k-250115
# 若模型不支持 response_format=json_object（如 doubao-seed-2-0-lite），可设 false；不设也会自动回退
# ARK_CHAT_JSON_MODE=false

# --- 路径（默认即可）---
PDF_INPUT_PATH=pdf/GBT 1568-2008 键 技术条件.pdf
PARSED_OUTPUT_DIR=artifacts/parsed
FAISS_INDEX_DIR=artifacts/faiss
BM25_INDEX_PATH=artifacts/bm25_index.pkl
MINERU_OUTPUT_DIR=artifacts/mineru
# --- 会话聊天 API + MongoDB ---
API_BASE_URL=http://127.0.0.1:8000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pdf_agent

# --- Langfuse 自托管观测（替代 artifacts/usage/*.jsonl）---
# 先运行: bash scripts/start_langfuse.sh → UI http://localhost:3000 → 复制 API Keys
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# 默认记录 Generation/Span 的 input/output（单字段最长约 4000 字符）
LANGFUSE_LOG_IO=true
# LANGFUSE_IO_MAX_CHARS=4000

# 已弃用（不再写入 JSONL，仅兼容旧配置）
# USAGE_LOG_DIR=artifacts/usage

# --- 可选：VL 按页校对 OCR（需 ARK VL 模型权限；禁止臆造补全条文）---
# OCR_VL_CORRECTION_ENABLED=false
